    "postgres": "^3.4.5",
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@bgcf/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
