# Copy to .env.local for local development. NEVER commit real values.
# Per-tier .env files (.env.local, .env.staging, .env.production) are gitignored.
# Staging/prod secrets live in Railway env vars and are pulled with `railway run`.

# ───── Core ─────
NODE_ENV=development                          # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ───── Supabase ─────
# Local Supabase (`supabase start`) prints these. Cloud projects expose them in Settings → API.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                    # server-only, never exposed to client
DATABASE_URL=                                 # postgres connection string (use the *pooler* URL in cloud)
DIRECT_DATABASE_URL=                          # non-pooler URL — drizzle-kit migrations need this

# ───── Stripe (Connect platform account) ─────
STRIPE_SECRET_KEY=                            # sk_test_… in local/staging
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=           # pk_test_…
STRIPE_WEBHOOK_SECRET=                        # whsec_… (printed by `stripe listen`)
STRIPE_CONNECT_CLIENT_ID=                     # ca_… (Connect platform)

# ───── Resend (transactional email) ─────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@mail-staging.example.com

# ───── Object storage (Cloudflare R2) ─────
# Get these from your Cloudflare R2 dashboard. See docs/SETUP.md.
STORAGE_ENDPOINT=                             # https://<accountid>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=                               # e.g. bgcf-media-staging
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
NEXT_PUBLIC_STORAGE_PUBLIC_URL=               # CDN/public URL prefix — e.g. https://media-staging.example.com

# ───── Background jobs (pg-boss) ─────
PG_BOSS_DATABASE_URL=                         # can be the same as DATABASE_URL
WORKER_CONCURRENCY=10

# ───── Cron auth ─────
CRON_SECRET=                                  # bearer token verifying internal cron hits — generate `openssl rand -hex 32`
